{
  "apps": [
    {
      "id": "app-prod-pg",
      "name": "prod-postgres",
      "organization": "my-org",
      "is_database": true,
      "public_ips": ["1.2.3.4"],
      "env_variables": {
        "PRIMARY_REGION": "ams",
        "DATABASE_URL": "postgres://superuser:super-secret@localhost:5432/db"
      },
      "machines": [
        {
          "id": "mac-111",
          "name": "ams-pg-1",
          "state": "started",
          "image": "flyio/postgres:15.3",
          "privileged": false,
          "region": "ams",
          "services": [
            {
              "internal_port": 5432,
              "external_port": 5432,
              "handlers": []
            }
          ]
        }
      ]
    },
    {
      "id": "app-web-front",
      "name": "web-frontend",
      "organization": "my-org",
      "is_database": false,
      "public_ips": ["5.6.7.8"],
      "env_variables": {},
      "machines": [
        {
          "id": "mac-222",
          "name": "ams-web-1",
          "state": "started",
          "image": "my-web-app:latest",
          "privileged": false,
          "region": "ams"
        }
      ]
    }
  ],
  "volumes": [
    {
      "id": "vol-1",
      "name": "pg_data",
      "app_id": "app-prod-pg",
      "state": "attached",
      "size_gb": 50,
      "encrypted": true
    },
    {
      "id": "vol-2",
      "name": "stale_temp_data",
      "app_id": "app-web-front",
      "state": "detached",
      "size_gb": 10,
      "encrypted": true
    }
  ],
  "networks": []
}
